# Supabase Postgres connection (use the Session/Transaction pooler string from
# Supabase -> Project Settings -> Database -> Connection string -> URI).
# IMPORTANT: URL-encode special characters in the password (e.g. '@' -> '%40').
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres

# --- Supabase auth ---
# Project URL, e.g. https://<project-ref>.supabase.co
SUPABASE_URL=https://<project-ref>.supabase.co
# Public anon key (Project Settings -> API). Used for token verification fallback.
SUPABASE_ANON_KEY=
# Optional: HS256 JWT secret (Project Settings -> API -> JWT Secret) for fast
# local token verification. If empty, the backend verifies via Supabase's API.
SUPABASE_JWT_SECRET=
# Service-role key — required only to provision staff auth users from the admin UI.
SUPABASE_SERVICE_ROLE_KEY=

CORS_ORIGINS=http://localhost:3000
UPLOAD_DIR=uploads
APP_NAME=NexaCargo API
VERSION=1.0.0
DEBUG=True
